{
  "name": "homebridge-smartbed-mqtt",
  "displayName": "Smart Bed MQTT",
  "version": "1.0.0",
  "description": "Homebridge plugin that exposes beds published by richardhopton/smartbed-mqtt (Sleeptracker, ErgoMotion, Linak, Richmat, Keeson, Octo, and all other supported bed types) to HomeKit, by consuming the Home Assistant MQTT Discovery messages the add-on already publishes.",
  "license": "MIT",
  "author": {
    "name": "solelo",
    "url": "https://github.com/solelo"
  },
  "keywords": [
    "homebridge-plugin",
    "smartbed",
    "smartbed-mqtt",
    "mqtt",
    "bed",
    "adjustable-bed",
    "homekit"
  ],
  "engines": {
    "node": "^22.5.1 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "watch": "npm run build && npm link && nodemon",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solelo/homebridge-smartbed-mqtt.git"
  },
  "bugs": {
    "url": "https://github.com/solelo/homebridge-smartbed-mqtt/issues"
  },
  "homepage": "https://github.com/solelo/homebridge-smartbed-mqtt#readme",
  "dependencies": {
    "mqtt": "^5.10.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "homebridge": "^2.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.2.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/test"],
    "collectCoverageFrom": ["src/**/*.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.jest.json" }]
    }
  }
}
